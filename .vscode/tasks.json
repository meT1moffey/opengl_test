{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ сборка активного файла",
            "command": "g++",
            "args": [
                "--std=c++23",
                "src/main.cpp",
                "glad/src/glad.c",
                "-o", "${workspaceFolder}/bin/main",
                "-I", "glad/include",
                "-lglfw"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Задача создана отладчиком."
        }
    ],
    "version": "2.0.0"
}